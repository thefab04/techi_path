import React, { useState } from "react";

function SearchBox() {
  const [query, setQuery] = useState("");
  const [response, setResponse] = useState("");
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  const handleSearch = async () => {
    if (!query) return;
    setLoading(true);
    setError("");
    setResponse("");

    try {
      const res = await fetch("http://localhost:11434/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          model: "your_model_name", // replace with your model
          messages: [
            { role: "user", content: query }
          ]
        }),
      });

      if (!res.ok) throw new Error("Error fetching response from Ollama model");

      const data = await res.json();

      // Adjust path depending on how your Ollama model returns the text
      const modelResponse = data?.choices?.[0]?.message?.content || "No response";
      setResponse(modelResponse);
    } catch (err) {
      setError(err.message);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="searchbox" style={{ padding: "2rem", textAlign: "center", fontFamily: "Arial" }}>
      <h1>Got a Doubt? Find Your Answer</h1>
      <input
        type="text"
        value={query}
        onChange={(e) => setQuery(e.target.value)}
        placeholder="Type your question..."
        style={{ width: "300px", padding: "0.5rem", marginBottom: "1rem" }}
      />
      <br />
      <button onClick={handleSearch} style={{ padding: "0.5rem 1rem" }}>
        Search
      </button>

      {loading && <p>Loading...</p>}
      {error && <p style={{ color: "red" }}>{error}</p>}
      {response && (
        <div className="response" style={{ marginTop: "2rem", textAlign: "left", maxWidth: "600px", margin: "2rem auto", padding: "1rem", background: "#f1f1f1", borderRadius: "8px" }}>
          <h4>Top Response:</h4>
          <p>{response}</p>
        </div>
      )}
    </div>
  );
}

export default SearchBox;
